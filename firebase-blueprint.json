{
  "entities": {
    "User": {
      "title": "User",
      "description": "A developer user profile.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user." },
        "email": { "type": "string", "format": "email", "description": "The email address of the user." },
        "displayName": { "type": "string", "description": "The display name of the user." },
        "photoURL": { "type": "string", "format": "uri", "description": "The URL of the user's profile photo." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The time the user profile was created." }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Blueprint": {
      "title": "Blueprint",
      "description": "A generated project blueprint.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the blueprint." },
        "userId": { "type": "string", "description": "The ID of the user who generated the blueprint." },
        "title": { "type": "string", "description": "The title of the project." },
        "description": { "type": "string", "description": "The project description." },
        "techStack": { 
          "type": "array",
          "items": { "type": "string" },
          "description": "The list of technologies used."
        },
        "erDiagram": { "type": "string", "description": "The ER diagram in Markdown format." },
        "features": { 
          "type": "array",
          "items": { "type": "string" },
          "description": "The core features of the project."
        },
        "implementationPlan": { 
          "type": "array",
          "items": { "type": "string" },
          "description": "The step-by-step implementation plan."
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "The time the blueprint was created." }
      },
      "required": ["userId", "title", "description", "techStack", "erDiagram", "features", "implementationPlan", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/blueprints/{blueprintId}": {
      "schema": "Blueprint",
      "description": "Generated blueprints."
    }
  }
}
